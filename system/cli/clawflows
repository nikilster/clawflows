# Create workflow from JSON (for agent/programmatic use)
_create_from_json() {
  local json="$1"

  if [ -z "$json" ]; then
    json="$(cat)"
  fi

  if [ -z "$json" ]; then
    die "No JSON provided. Usage: clawflows create --from-json '{...}' or pipe JSON to stdin"
  fi

  # Parse JSON fields (|| true for optional fields that may not exist)
  local name emoji summary schedule author description visibility
  name="$(echo "$json" | grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  emoji="$(echo "$json" | grep -o '"emoji"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  summary="$(echo "$json" | grep -o '"summary"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  schedule="$(echo "$json" | grep -o '"schedule"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  author="$(echo "$json" | grep -o '"author"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  description="$(echo "$json" | grep -o '"description"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  visibility="$(echo "$json" | grep -o '"visibility"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  visibility="${visibility:-public}"
  case "$visibility" in
    public|private|hidden|no-sync) ;;
    *) visibility="public" ;;
  esac

  # Decode JSON escape sequences (e.g. \n from textarea input)
  description="$(printf '%s' "$description" | awk '{gsub(/\\n/,"\n")}1')"

  # Validate required fields
  [ -n "$name" ] || die "Missing required field: name"
  validate_workflow_name "$name"
  [ -n "$summary" ] || die "Missing required field: summary"
  [ -n "$description" ] || die "Missing required field: description"

  # Defaults
  emoji="${emoji:-🔧}"

  # Check if already exists
  if [ -d "$CREATED_DIR/$name" ] || [ -n "$(_find_workflow "$name")" ]; then
    die "Workflow '$name' already exists"
  fi

  # Build the WORKFLOW.md content
  local workflow_content="---
name: $name
emoji: \"$emoji\"
description: $summary"

  if [ -n "$schedule" ]; then
    workflow_content="$workflow_content
schedule: \"$schedule\""
  fi

  if [ -n "$author" ]; then
    workflow_content="$workflow_content
author: $author"
  fi

  if [ -n "$visibility" ] && [ "$visibility" != "public" ]; then
    workflow_content="$workflow_content
visibility: $visibility"
  fi

  local title
  title="$(echo "${name//-/ }" | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1')"

  workflow_content="$workflow_content
---

# $title

$description
"

  # Create in created/ directory
  local workflow_dir="$CREATED_DIR/$name"
  mkdir -p "$workflow_dir"
  printf '%s' "$workflow_content" > "$workflow_dir/WORKFLOW.md"

  echo "✓ Created $workflow_dir/WORKFLOW.md"

  # Auto-enable it
  cmd_enable "$name"

  # Show how to use it
  echo ""
  echo "To run: ask your agent \"Run $name\""
  if [ -n "$schedule" ]; then
    echo "Scheduled: $schedule"
  fi
  echo "To edit: $workflow_dir/WORKFLOW.md"

  # Auto-sync to web if logged in
  if [ -f "$HUB_TOKEN_FILE" ]; then
    cmd_web_sync
  fi
}

cmd_create() {
  if [ "${1:-}" = "--from-json" ]; then
    _create_from_json "${2:-}"
    return
  fi

  echo ""
  echo "  ⚡️ Create a new workflow"
  echo ""

  # 1. Name
  local name=""
  while [ -z "$name" ]; do
    printf "  Name (e.g., check-water-intake): "
    read -r name
    if [ -n "$name" ]; then
      name="$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"
      # Validate name format
      if ! printf '%s' "$name" | grep -qE '^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$'; then
        echo "  ⚠️  Invalid name: use only letters, numbers, dashes, underscores (max 64 chars)"
        name=""
        continue
      fi
      # Suggest a verb-prefixed name if they didn't use one
      if ! echo "$name" | grep -qE '^(activate|process|check|build|send|sync|track|draft|review|plan|prep|curate|summarize|backup|clean|rotate|find)-'; then
        echo "  💡 Tip: names usually start with a verb like check-$name or track-$name"
      fi
      if [ -d "$CREATED_DIR/$name" ] || [ -n "$(_find_workflow "$name")" ]; then
        echo "  ⚠️  Workflow '$name' already exists"
        name=""
        continue
      fi
    fi
  done

  # 2. Emoji
  printf "  Emoji (e.g., 💧): "
  read -r emoji
  emoji="${emoji:-🔧}"

  # 3. Summary
  local summary=""
  while [ -z "$summary" ]; do
    printf "  One-line summary: "
    read -r summary
  done

  # 4. Schedule
  echo ""
  echo "  When should it run?"
  echo "    Examples: \"9am\", \"9am, 5pm\", \"8am, 12pm, 4pm, 8pm\""
  echo "    Leave blank for on-demand only"
  printf "  Schedule: "
  read -r schedule

  # 5. Visibility
  echo ""
  echo "  Visibility on ClawFlows.ai?"
  echo "    public   — fully visible and installable (default)"
  echo "    private  — name & description only, others can request access"
  echo "    hidden   — only visible to you"
  echo "    no-sync  — never uploaded to the web"
  printf "  Visibility [public]: "
  read -r visibility
  visibility="${visibility:-public}"
  case "$visibility" in
    public|private|hidden|no-sync) ;;
    *) echo "  ⚠️  Unknown visibility '$visibility', defaulting to public"
       visibility="public" ;;
  esac

  # 6. Author
  echo ""
  echo "  Your name (optional, for credit)"
  echo "    GitHub username, @twitter, or both: \"nikilster @nikil\""
  printf "  You: "
  read -r author

  # 7. Description
  echo ""
  echo "  Describe what this workflow does."
  echo "  What should the agent do when running it? Be specific."
  echo "  Keep it generic — say \"the user\" instead of your name,"
  echo "  and don't hardcode locations, apps, or personal details."
  echo "  (Enter a blank line when done)"
  echo ""
  local description=""
  local line
  while IFS= read -r line; do
    [ -z "$line" ] && break
    if [ -z "$description" ]; then
      description="$line"
    else
      description="$description"$'\n'"$line"
    fi
  done

  # Build content
  local workflow_content="---
name: $name
emoji: \"$emoji\"
description: $summary"

  if [ -n "$schedule" ]; then
    workflow_content="$workflow_content
schedule: \"$schedule\""
  fi

  if [ -n "$author" ]; then
    workflow_content="$workflow_content
author: $author"
  fi

  if [ "$visibility" != "public" ]; then
    workflow_content="$workflow_content
visibility: $visibility"
  fi

  local title
  title="$(echo "${name//-/ }" | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1')"

  workflow_content="$workflow_content
---

# $title

$description
"

  # Create in created/ directory
  local workflow_dir="$CREATED_DIR/$name"
  mkdir -p "$workflow_dir"
  printf '%s' "$workflow_content" > "$workflow_dir/WORKFLOW.md"

  echo ""
  echo "  ✓ Created $workflow_dir/WORKFLOW.md"
  echo ""
  echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "$workflow_content" | sed 's/^/  /'
  echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  # Auto-enable
  cmd_enable "$name"

  echo ""
  echo "  Your workflow is ready!"
  echo ""
  echo "  To run:  ask your agent \"Run $name\""
  if [ -n "$schedule" ]; then
    echo "  Scheduled: $schedule"
  fi
  echo "  To edit: $workflow_dir/WORKFLOW.md"
  echo ""

  # Auto-sync to web if logged in
  if [ -f "$HUB_TOKEN_FILE" ]; then
    cmd_web_sync
  fi
}

cmd_list() {
  local filter="${1:-all}"
  local name dir found=false
  local enabled_lines=()
  local available_lines=()
  local seen_names=""

  # Collect created workflows
  for dir in "$CREATED_DIR"/*/; do
    [ -d "$dir" ] || continue
    name="$(basename "$dir")"
    [ "$name" = ".gitkeep" ] && continue
    seen_names="$seen_names $name "
    found=true

    if [ -L "$ENABLED_DIR/$name" ] || [ -d "$ENABLED_DIR/$name" ]; then
      enabled_lines+=("$(_workflow_line "$dir" "created")")
    else
      available_lines+=("$(_workflow_line "$dir" "created")")
    fi
  done

  # Collect installed workflows (from web)
  if [ -d "$INSTALLED_DIR" ]; then
    for agent_dir in "$INSTALLED_DIR"/*/; do
      [ -d "$agent_dir" ] || continue
      local agent_label
      if [ -f "$agent_dir.agent.json" ]; then
        agent_label="@$(python3 -c 'import sys,json; print(json.load(sys.stdin).get("username","unknown"))' < "$agent_dir.agent.json" 2>/dev/null)"
      else
        agent_label="@$(basename "$agent_dir")"
      fi
      for dir in "$agent_dir"*/; do
        [ -d "$dir" ] || continue
        name="$(basename "$dir")"
        case "$seen_names" in
          *" $name "*) continue ;;
        esac
        seen_names="$seen_names $name "
        found=true

        if [ -L "$ENABLED_DIR/$name" ] || [ -d "$ENABLED_DIR/$name" ]; then
          enabled_lines+=("$(_workflow_line "$dir" "$agent_label")")
        else
          available_lines+=("$(_workflow_line "$dir" "$agent_label")")
        fi
      done
    done
  fi

  if ! $found; then
    echo ""
    echo "  No workflows found."
    echo ""
    echo "  Browse workflows at https://clawflows.ai"
    echo ""
    return
  fi

  if [ "$filter" = "all" ] || [ "$filter" = "enabled" ]; then
    if [ ${#enabled_lines[@]} -gt 0 ]; then
      echo ""
      echo "  Enabled (${#enabled_lines[@]})"
      echo "  ──────────"
      for line in "${enabled_lines[@]}"; do
        echo "$line"
      done
    fi
    if [ "$filter" = "enabled" ] && [ ${#enabled_lines[@]} -eq 0 ]; then
      echo ""
      echo "  No workflows enabled yet."
      echo "  Run 'clawflows list' to see what's available."
    fi
  fi

  if [ "$filter" = "all" ] || [ "$filter" = "available" ]; then
    if [ ${#available_lines[@]} -gt 0 ]; then
      echo ""
      echo "  Available (${#available_lines[@]})"
      echo "  ─────────────"
      for line in "${available_lines[@]}"; do
        echo "$line"
      done
    fi
  fi

  echo ""
  echo "  clawflows enable <name>    Turn on a workflow"
  echo "  clawflows disable <name>   Turn off a workflow"
}

cmd_enable() {
  local name="$1"
  validate_workflow_name "$name"
  local source_dir
  source_dir="$(_find_workflow "$name")"

  [ -n "$source_dir" ] || die "workflow '$name' not found"

  if [ -L "$ENABLED_DIR/$name" ] || [ -d "$ENABLED_DIR/$name" ]; then
    echo "already enabled: $name"
    return
  fi

  # Create symlink
  ln -s "$source_dir" "$ENABLED_DIR/$name"

  # Show a friendly enable message
  local wf_file="$source_dir/WORKFLOW.md"
  local emoji desc schedule
  emoji="$(get_field "$wf_file" emoji)"
  desc="$(get_field "$wf_file" description)"
  schedule="$(get_field "$wf_file" schedule)"

  local label="${emoji:+$emoji }$name"
  echo ""
  echo "  $label enabled"
  if [ -n "$desc" ]; then
    echo "  $desc"
  fi
  if [ -n "$schedule" ]; then
    echo "  Runs daily at $schedule"
  else
    echo "  On-demand — run anytime with: clawflows run $name"
  fi
  echo ""

  # If this workflow has a schedule, ensure the scheduler cron is set up
  if [ -n "$schedule" ]; then
    local oc
    oc="$(_find_openclaw)"
    if [ -n "$oc" ] && ! "$oc" cron list </dev/null 2>/dev/null | grep -q "clawflows-scheduler"; then
      "$oc" cron add \
        --name "clawflows-scheduler" \
        --cron "*/15 * * * *" \
        --session isolated \
        --message "Read and execute $CLAWFLOWS_DIR/system/scheduler.md" \
        --no-deliver </dev/null >/dev/null 2>&1 || true
    fi
  fi

  cmd_sync >/dev/null 2>&1
}

cmd_disable() {
  local name="$1"
  validate_workflow_name "$name"
  if [ ! -L "$ENABLED_DIR/$name" ] && [ ! -d "$ENABLED_DIR/$name" ]; then
    echo "not enabled: $name"
    return
  fi

  # Remove symlink (or directory if somehow it's not a symlink)
  rm -rf "$ENABLED_DIR/$name"
  echo "disabled: $name"
  cmd_sync
}

cmd_edit() {
  local name="$1"
  validate_workflow_name "$name"

  # Already in created/? Just show the path
  if [ -d "$CREATED_DIR/$name" ]; then
    echo "workflow is in created/: $name"
    echo ""
    echo "  Edit: $CREATED_DIR/$name/WORKFLOW.md"
    return
  fi

  # Installed workflow? Copy to created/ so they can edit it
  local source_dir
  source_dir="$(_find_workflow "$name")"
  if [ -n "$source_dir" ]; then
    cp -r "$source_dir" "$CREATED_DIR/$name"
    echo "copied to created/: $name"

    # If it was enabled, update the symlink to point to created/
    if [ -L "$ENABLED_DIR/$name" ]; then
      rm "$ENABLED_DIR/$name"
      ln -s "$CREATED_DIR/$name" "$ENABLED_DIR/$name"
      echo "updated symlink to created version"
    fi

    echo ""
    echo "  Edit: $CREATED_DIR/$name/WORKFLOW.md"
    return
  fi

  die "workflow '$name' not found"
}

cmd_open() {
  local name="$1"
  validate_workflow_name "$name"
  local source_dir
  source_dir="$(_find_workflow "$name")"
  [ -n "$source_dir" ] || die "workflow '$name' not found"
  local wf_file="$source_dir/WORKFLOW.md"

  [ -f "$wf_file" ] || die "WORKFLOW.md not found at $wf_file"

  # Find an editor
  local editor="${EDITOR:-}"
  if [ -z "$editor" ]; then
    # Try common editors
    for e in code vim nano vi; do
      if command -v "$e" >/dev/null 2>&1; then
        editor="$e"
        break
      fi
    done
  fi

  if [ -z "$editor" ]; then
    echo "No editor found. Set \$EDITOR or install vim/nano."
    echo ""
    echo "  File: $wf_file"
    return 1
  fi

  echo "Opening $wf_file..."
  $editor "$wf_file"
}

cmd_update() {
  echo "Updating clawflows..."

  # Capture current updates.md content before pulling
  local updates_file="$CLAWFLOWS_DIR/docs/updates.md"
  local old_updates=""
  if [ -f "$updates_file" ]; then
    old_updates="$(cat "$updates_file")"
  fi

  if git -C "$CLAWFLOWS_DIR" pull --ff-only --quiet 2>/dev/null; then
    echo "Updated to latest version."
  else
    echo "Could not update (offline or local changes). Try: git -C $CLAWFLOWS_DIR pull"
    return 1
  fi

  # Show what's new by diffing updates.md
  if [ -f "$updates_file" ]; then
    local new_updates
    new_updates="$(cat "$updates_file")"
    if [ "$old_updates" != "$new_updates" ] && [ -n "$old_updates" ]; then
      # Extract lines that are new (present in new but not in old)
      local new_lines
      new_lines="$(diff <(echo "$old_updates") <(echo "$new_updates") | grep '^> ' | sed 's/^> //' || true)"
      # Filter to just the bullet point entries (skip headings and blank lines)
      local entries
      entries="$(echo "$new_lines" | grep '^- ' || true)"
      if [ -n "$entries" ]; then
        echo ""
        echo "What's new:"
        echo "$entries"
      fi
    elif [ -z "$old_updates" ]; then
      echo ""
      echo "Release notes available at: docs/updates.md"
    fi
  fi

  cmd_sync
  echo ""
  echo "IMPORTANT: Re-read your AGENTS.md file now to pick up any new instructions or workflows."
}

cmd_uninstall() {
  echo ""
  echo "  This will remove:"
  echo "    • CLI symlink at $BIN_TARGET"
  echo "    • ClawFlows section from AGENTS.md"
  echo "    • Scheduler cron job"
  echo ""
  echo "  Your created workflows in $CREATED_DIR/ will NOT be deleted."
  echo "  The repo at $CLAWFLOWS_DIR/ will NOT be deleted."
  echo ""
  printf "  Are you sure? [y/N] "
  read -r confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    echo "  Cancelled."
    return
  fi

  if [ -L "$BIN_TARGET" ]; then
    rm -f "$BIN_TARGET"
    echo "  Removed $BIN_TARGET"
  fi

  if [ -f "$AGENTS_MD" ] && grep -qF "$START_MARKER" "$AGENTS_MD"; then
    local tmpfile
    tmpfile="$(mktemp)"
    awk -v start="$START_MARKER" -v end="$END_MARKER" '
      $0 == start { skip=1; next }
      $0 == end   { skip=0; next }
      !skip       { print }
    ' "$AGENTS_MD" > "$tmpfile"
    mv "$tmpfile" "$AGENTS_MD"
    echo "  Removed ClawFlows section from AGENTS.md"
  fi

  local oc
  oc="$(_find_openclaw)"
  if [ -n "$oc" ]; then
    "$oc" cron remove --name "clawflows-scheduler" </dev/null >/dev/null 2>&1 || true
    echo "  Removed scheduler cron"
  fi

  echo ""
  echo "  Done. To fully remove, also run:"
  echo "    rm -rf $CLAWFLOWS_DIR"
  echo ""
  echo "  ⚠️  Warning: This will delete any workflows you created."
  echo "     Back up $CREATED_DIR/ first if you want to keep them."
  echo ""
}

cmd_doctor() {
  echo ""
  echo "  🩺 ClawFlows Doctor"
  echo ""

  local issues=0

  # Check for non-symlink entries in enabled/
  for entry in "$ENABLED_DIR"/*/; do
    [ -d "$entry" ] || continue
    local name
    name="$(basename "$entry")"
    if [ ! -L "$ENABLED_DIR/$name" ]; then
      echo "  ⚠️  $name is a direct copy in enabled/ (should be a symlink)"
      echo "     Fix: move to available/created/$name/ and symlink back"
      issues=$((issues + 1))
    fi
  done

  # Check for broken symlinks in enabled/
  for entry in "$ENABLED_DIR"/*; do
    [ -L "$entry" ] || continue
    if [ ! -e "$entry" ]; then
      local name
      name="$(basename "$entry")"
      echo "  ❌ $name is a broken symlink (target missing)"
      echo "     Target: $(readlink "$entry")"
      issues=$((issues + 1))
    fi
  done

  # Check for workflows not in available/created/
  for entry in "$ENABLED_DIR"/*; do
    [ -L "$entry" ] || continue
    [ -e "$entry" ] || continue
    local target
    target="$(readlink "$entry")"
    local name
    name="$(basename "$entry")"
    if [[ "$target" != *"/available/created/"* ]] && [[ "$target" != *"/available/installed/"* ]] && [[ "$target" != *"/available/community/"* ]]; then
      echo "  ⚠️  $name symlink points outside available/: $target"
      issues=$((issues + 1))
    fi
  done

  if [ "$issues" -eq 0 ]; then
    echo "  ✅ All workflows look healthy!"
    echo "     All enabled workflows are proper symlinks."
  else
    echo ""
    echo "  Found $issues issue(s)."
  fi
  echo ""
}

cmd_sync() {
  local block
  block="$(_build_block)"

  if [ ! -f "$AGENTS_MD" ]; then
    echo "note: AGENTS.md not found at $AGENTS_MD (skipping sync)"
    return 0
  fi

  if grep -qF "$START_MARKER" "$AGENTS_MD"; then
    _replace_block "$block"
  else
    printf "\n%s\n" "$block" >> "$AGENTS_MD"
  fi

  echo "synced AGENTS.md"
}

