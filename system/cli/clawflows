# Create workflow from JSON (for agent/programmatic use)
_create_from_json() {
  local json="$1"

  if [ -z "$json" ]; then
    json="$(cat)"
  fi

  if [ -z "$json" ]; then
    die "No JSON provided. Usage: clawflows create --from-json '{...}' or pipe JSON to stdin"
  fi

  # Parse JSON fields (|| true for optional fields that may not exist)
  local name emoji summary schedule author description visibility
  name="$(echo "$json" | grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  emoji="$(echo "$json" | grep -o '"emoji"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  summary="$(echo "$json" | grep -o '"summary"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  schedule="$(echo "$json" | grep -o '"schedule"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  author="$(echo "$json" | grep -o '"author"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  description="$(echo "$json" | grep -o '"description"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  visibility="$(echo "$json" | grep -o '"visibility"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
  visibility="${visibility:-public}"
  case "$visibility" in
    public|private|hidden|no-sync) ;;
    *) visibility="public" ;;
  esac

  # Decode JSON escape sequences (e.g. \n from textarea input)
  description="$(printf '%s' "$description" | awk '{gsub(/\\n/,"\n")}1')"

  # Validate required fields
  [ -n "$name" ] || die "Missing required field: name"
  validate_workflow_name "$name"
  [ -n "$summary" ] || die "Missing required field: summary"
  [ -n "$description" ] || die "Missing required field: description"

  # Defaults
  emoji="${emoji:-🔧}"

  # Check if already exists
  if [ -d "$CREATED_DIR/$name" ] || [ -n "$(_find_workflow "$name")" ]; then
    die "Workflow '$name' already exists"
  fi

  # Build the WORKFLOW.md content
  local workflow_content="---
name: $name
emoji: \"$emoji\"
description: $summary"

  if [ -n "$schedule" ]; then
    workflow_content="$workflow_content
schedule: \"$schedule\""
  fi

  if [ -n "$author" ]; then
    workflow_content="$workflow_content
author: $author"
  fi

  if [ -n "$visibility" ] && [ "$visibility" != "public" ]; then
    workflow_content="$workflow_content
visibility: $visibility"
  fi

  local title
  title="$(echo "${name//-/ }" | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1')"

  workflow_content="$workflow_content
---

# $title

$description
"

  # Create in created/ directory
  local workflow_dir="$CREATED_DIR/$name"
  mkdir -p "$workflow_dir"
  printf '%s' "$workflow_content" > "$workflow_dir/WORKFLOW.md"

  echo "✓ Created $workflow_dir/WORKFLOW.md"

  # Auto-enable it
  cmd_enable "$name"

  # Show how to use it
  echo ""
  echo "To run: ask your agent \"Run $name\""
  if [ -n "$schedule" ]; then
    echo "Scheduled: $schedule"
  fi
  echo "To edit: $workflow_dir/WORKFLOW.md"

  # Auto-sync to web if logged in
  if [ -f "$HUB_TOKEN_FILE" ]; then
    cmd_web_sync
  fi
}

cmd_create() {
  if [ "${1:-}" = "--from-json" ]; then
    _create_from_json "${2:-}"
    return
  fi

  echo ""
  echo "  ⚡️ Create a new workflow"
  echo ""

  # 1. Name
  local name=""
  while [ -z "$name" ]; do
    printf "  Name (e.g., check-water-intake): "
    read -r name
    if [ -n "$name" ]; then
      name="$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"
      # Validate name format
      if ! printf '%s' "$name" | grep -qE '^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$'; then
        echo "  ⚠️  Invalid name: use only letters, numbers, dashes, underscores (max 64 chars)"
        name=""
        continue
      fi
      # Suggest a verb-prefixed name if they didn't use one
      if ! echo "$name" | grep -qE '^(activate|process|check|build|send|sync|track|draft|review|plan|prep|curate|summarize|backup|clean|rotate|find)-'; then
        echo "  💡 Tip: names usually start with a verb like check-$name or track-$name"
      fi
      if [ -d "$CREATED_DIR/$name" ] || [ -n "$(_find_workflow "$name")" ]; then
        echo "  ⚠️  Workflow '$name' already exists"
        name=""
        continue
      fi
    fi
  done

  # 2. Emoji
  printf "  Emoji (e.g., 💧): "
  read -r emoji
  emoji="${emoji:-🔧}"

  # 3. Summary
  local summary=""
  while [ -z "$summary" ]; do
    printf "  One-line summary: "
    read -r summary
  done

  # 4. Schedule
  echo ""
  echo "  When should it run?"
  echo "    Examples: \"9am\", \"9am, 5pm\", \"8am, 12pm, 4pm, 8pm\""
  echo "    Leave blank for on-demand only"
  printf "  Schedule: "
  read -r schedule

  # 5. Visibility
  echo ""
  echo "  Visibility on ClawFlows.ai?"
  echo "    public   — fully visible and installable (default)"
  echo "    private  — name & description only, others can request access"
  echo "    hidden   — only visible to you"
  echo "    no-sync  — never uploaded to the web"
  printf "  Visibility [public]: "
  read -r visibility
  visibility="${visibility:-public}"
  case "$visibility" in
    public|private|hidden|no-sync) ;;
    *) echo "  ⚠️  Unknown visibility '$visibility', defaulting to public"
       visibility="public" ;;
  esac

  # 6. Author
  echo ""
  echo "  Your name (optional, for credit)"
  echo "    GitHub username, @twitter, or both: \"nikilster @nikil\""
  printf "  You: "
  read -r author

  # 7. Description
  echo ""
  echo "  Describe what this workflow does."
  echo "  What should the agent do when running it? Be specific."
  echo "  Keep it generic — say \"the user\" instead of your name,"
  echo "  and don't hardcode locations, apps, or personal details."
  echo "  (Enter a blank line when done)"
  echo ""
  local description=""
  local line
  while IFS= read -r line; do
    [ -z "$line" ] && break
    if [ -z "$description" ]; then
      description="$line"
    else
      description="$description"$'\n'"$line"
    fi
  done

  # Build content
  local workflow_content="---
name: $name
emoji: \"$emoji\"
description: $summary"

  if [ -n "$schedule" ]; then
    workflow_content="$workflow_content
schedule: \"$schedule\""
  fi

  if [ -n "$author" ]; then
    workflow_content="$workflow_content
author: $author"
  fi

  if [ "$visibility" != "public" ]; then
    workflow_content="$workflow_content
visibility: $visibility"
  fi

  local title
  title="$(echo "${name//-/ }" | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1')"

  workflow_content="$workflow_content
---

# $title

$description
"

  # Create in created/ directory
  local workflow_dir="$CREATED_DIR/$name"
  mkdir -p "$workflow_dir"
  printf '%s' "$workflow_content" > "$workflow_dir/WORKFLOW.md"

  echo ""
  echo "  ✓ Created $workflow_dir/WORKFLOW.md"
  echo ""
  echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "$workflow_content" | sed 's/^/  /'
  echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  # Auto-enable
  cmd_enable "$name"

  echo ""
  echo "  Your workflow is ready!"
  echo ""
  echo "  To run:  ask your agent \"Run $name\""
  if [ -n "$schedule" ]; then
    echo "  Scheduled: $schedule"
  fi
  echo "  To edit: $workflow_dir/WORKFLOW.md"
  echo ""

  # Auto-sync to web if logged in
  if [ -f "$HUB_TOKEN_FILE" ]; then
    cmd_web_sync
  fi
}

cmd_list() {
  local filter="${1:-all}"
  local name dir found=false
  local enabled_lines=()
  local available_lines=()
  local seen_names=""

  # Read clawflows.json to know which workflows are enabled
  local clawflows_data
  clawflows_data="$(_json_read)"

  # Collect created workflows
  for dir in "$CREATED_DIR"/*/; do
    [ -d "$dir" ] || continue
    name="$(basename "$dir")"
    [ "$name" = ".gitkeep" ] && continue
    seen_names="$seen_names $name "
    found=true

    if _json_is_enabled "$name"; then
      enabled_lines+=("$(_workflow_line "$dir" "created")")
    else
      available_lines+=("$(_workflow_line "$dir" "created")")
    fi
  done

  # Collect installed workflows (from web)
  if [ -d "$INSTALLED_DIR" ]; then
    for agent_dir in "$INSTALLED_DIR"/*/; do
      [ -d "$agent_dir" ] || continue
      local agent_id_name
      agent_id_name="$(basename "$agent_dir")"
      # Get username from clawflows.json if enabled, otherwise from .agent.json
      for dir in "$agent_dir"*/; do
        [ -d "$dir" ] || continue
        name="$(basename "$dir")"
        case "$seen_names" in
          *" $name "*) continue ;;
        esac
        seen_names="$seen_names $name "
        found=true

        local agent_label
        # Try to get username from clawflows.json
        local reg_username
        reg_username="$(python3 -c "
import sys, json
data = json.loads(sys.argv[1])
for e in data:
    if e.get('name') == '$name':
        print(e.get('username', ''))
        break
" "$clawflows_data" 2>/dev/null)"
        if [ -n "$reg_username" ]; then
          agent_label="@$reg_username"
        elif [ -f "$agent_dir.agent.json" ]; then
          agent_label="@$(python3 -c 'import sys,json; print(json.load(sys.stdin).get("username","unknown"))' < "$agent_dir.agent.json" 2>/dev/null)"
        else
          agent_label="@$agent_id_name"
        fi

        if _json_is_enabled "$name"; then
          enabled_lines+=("$(_workflow_line "$dir" "$agent_label")")
        else
          available_lines+=("$(_workflow_line "$dir" "$agent_label")")
        fi
      done
    done
  fi

  if ! $found; then
    echo ""
    echo "  No workflows found."
    echo ""
    echo "  Browse workflows at https://clawflows.ai"
    echo ""
    return
  fi

  if [ "$filter" = "all" ] || [ "$filter" = "enabled" ]; then
    if [ ${#enabled_lines[@]} -gt 0 ]; then
      echo ""
      echo "  Enabled (${#enabled_lines[@]})"
      echo "  ──────────"
      for line in "${enabled_lines[@]}"; do
        echo "$line"
      done
    fi
    if [ "$filter" = "enabled" ] && [ ${#enabled_lines[@]} -eq 0 ]; then
      echo ""
      echo "  No workflows enabled yet."
      echo "  Run 'clawflows list' to see what's available."
    fi
  fi

  if [ "$filter" = "all" ] || [ "$filter" = "available" ]; then
    if [ ${#available_lines[@]} -gt 0 ]; then
      echo ""
      echo "  Available (${#available_lines[@]})"
      echo "  ─────────────"
      for line in "${available_lines[@]}"; do
        echo "$line"
      done
    fi
  fi

  echo ""
  echo "  clawflows enable <name>    Turn on a workflow"
  echo "  clawflows disable <name>   Turn off a workflow"
}

cmd_enable() {
  local name="$1"
  validate_workflow_name "$name"
  local source_dir
  source_dir="$(_find_workflow "$name")"

  [ -n "$source_dir" ] || die "workflow '$name' not found"

  if _json_is_enabled "$name"; then
    echo "already enabled: $name"
    return
  fi

  # Read metadata from WORKFLOW.md
  local wf_file="$source_dir/WORKFLOW.md"
  local emoji desc schedule source rel_path
  emoji="$(get_field "$wf_file" emoji)"
  desc="$(get_field "$wf_file" description)"
  schedule="$(get_field "$wf_file" schedule)"

  # Determine source and relative path
  case "$source_dir" in
    "$CREATED_DIR"/*)
      source="created"
      rel_path="created/$name"
      ;;
    "$INSTALLED_DIR"/*)
      source="installed"
      # Extract agent_id from path: installed/<agent_id>/<slug>
      local agent_id_dir
      agent_id_dir="$(echo "$source_dir" | sed "s|$INSTALLED_DIR/||" | cut -d/ -f1)"
      rel_path="installed/$agent_id_dir/$name"
      ;;
    *)
      source="created"
      rel_path="created/$name"
      ;;
  esac

  # Build clawflows.json entry
  local entry_json
  local now
  now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  if [ "$source" = "installed" ]; then
    local agent_id username version
    agent_id="$agent_id_dir"
    # Read username from .agent.json if it exists
    username=""
    if [ -f "$INSTALLED_DIR/$agent_id/.agent.json" ]; then
      username="$(python3 -c 'import sys,json; print(json.load(sys.stdin).get("username",""))' < "$INSTALLED_DIR/$agent_id/.agent.json" 2>/dev/null)"
    fi
    # Read version from clawflows.json or default to 1
    version="1"
    entry_json="{\"name\":\"$name\",\"schedule\":\"${schedule:-}\",\"path\":\"$rel_path\",\"source\":\"installed\",\"agent_id\":\"$agent_id\",\"username\":\"${username:-}\",\"version\":$version,\"created_at\":\"$now\"}"
  else
    entry_json="{\"name\":\"$name\",\"schedule\":\"${schedule:-}\",\"path\":\"$rel_path\",\"source\":\"created\",\"created_at\":\"$now\"}"
  fi

  _json_add "$entry_json"

  # Show a friendly enable message
  local label="${emoji:+$emoji }$name"
  echo ""
  echo "  $label enabled"
  if [ -n "$desc" ]; then
    echo "  $desc"
  fi
  if [ -n "$schedule" ]; then
    echo "  Runs daily at $schedule"
  else
    echo "  On-demand — run anytime with: clawflows run $name"
  fi
  echo ""

  # If this workflow has a schedule, ensure the scheduler cron is set up
  if [ -n "$schedule" ]; then
    local oc
    oc="$(_find_openclaw)"
    if [ -n "$oc" ] && ! "$oc" cron list </dev/null 2>/dev/null | grep -q "clawflows-scheduler"; then
      "$oc" cron add \
        --name "clawflows-scheduler" \
        --cron "*/15 * * * *" \
        --session isolated \
        --message "Read and execute $CLAWFLOWS_DIR/system/scheduler.md" \
        --no-deliver </dev/null >/dev/null 2>&1 || true
    fi
  fi

  cmd_sync >/dev/null 2>&1
}

cmd_disable() {
  local name="$1"
  validate_workflow_name "$name"
  if ! _json_is_enabled "$name"; then
    echo "not enabled: $name"
    return
  fi

  _json_remove "$name"
  echo "disabled: $name"
  cmd_sync
}

cmd_edit() {
  local name="$1"
  validate_workflow_name "$name"

  # Already in created/? Just show the path
  if [ -d "$CREATED_DIR/$name" ]; then
    echo "workflow is in created/: $name"
    echo ""
    echo "  Edit: $CREATED_DIR/$name/WORKFLOW.md"
    return
  fi

  # Installed workflow? Copy to created/ so they can edit it
  local source_dir
  source_dir="$(_find_workflow "$name")"
  if [ -n "$source_dir" ]; then
    cp -r "$source_dir" "$CREATED_DIR/$name"
    echo "copied to created/: $name"

    # If it was enabled, update clawflows.json entry to point to created/
    if _json_is_enabled "$name"; then
      local existing schedule now
      existing="$(_json_find "$name")"
      schedule="$(printf '%s' "$existing" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("schedule",""))' 2>/dev/null)"
      now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
      _json_add "{\"name\":\"$name\",\"schedule\":\"${schedule:-}\",\"path\":\"created/$name\",\"source\":\"created\",\"created_at\":\"$now\"}"
      echo "updated clawflows.json to created version"
    fi

    echo ""
    echo "  Edit: $CREATED_DIR/$name/WORKFLOW.md"
    return
  fi

  die "workflow '$name' not found"
}

cmd_open() {
  local name="$1"
  validate_workflow_name "$name"
  local source_dir
  source_dir="$(_find_workflow "$name")"
  [ -n "$source_dir" ] || die "workflow '$name' not found"
  local wf_file="$source_dir/WORKFLOW.md"

  [ -f "$wf_file" ] || die "WORKFLOW.md not found at $wf_file"

  # Find an editor
  local editor="${EDITOR:-}"
  if [ -z "$editor" ]; then
    # Try common editors
    for e in code vim nano vi; do
      if command -v "$e" >/dev/null 2>&1; then
        editor="$e"
        break
      fi
    done
  fi

  if [ -z "$editor" ]; then
    echo "No editor found. Set \$EDITOR or install vim/nano."
    echo ""
    echo "  File: $wf_file"
    return 1
  fi

  echo "Opening $wf_file..."
  $editor "$wf_file"
}

cmd_update() {
  echo "Updating clawflows..."

  # Capture current updates.md content before pulling
  local updates_file="$CLAWFLOWS_DIR/docs/updates.md"
  local old_updates=""
  if [ -f "$updates_file" ]; then
    old_updates="$(cat "$updates_file")"
  fi

  if git -C "$CLAWFLOWS_DIR" pull --ff-only --quiet 2>/dev/null; then
    echo "Updated to latest version."
  else
    echo "Could not update (offline or local changes). Try: git -C $CLAWFLOWS_DIR pull"
    return 1
  fi

  # Show what's new by diffing updates.md
  if [ -f "$updates_file" ]; then
    local new_updates
    new_updates="$(cat "$updates_file")"
    if [ "$old_updates" != "$new_updates" ] && [ -n "$old_updates" ]; then
      # Extract lines that are new (present in new but not in old)
      local new_lines
      new_lines="$(diff <(echo "$old_updates") <(echo "$new_updates") | grep '^> ' | sed 's/^> //' || true)"
      # Filter to just the bullet point entries (skip headings and blank lines)
      local entries
      entries="$(echo "$new_lines" | grep '^- ' || true)"
      if [ -n "$entries" ]; then
        echo ""
        echo "What's new:"
        echo "$entries"
      fi
    elif [ -z "$old_updates" ]; then
      echo ""
      echo "Release notes available at: docs/updates.md"
    fi
  fi

  cmd_sync
  echo ""
  echo "IMPORTANT: Re-read your AGENTS.md file now to pick up any new instructions or workflows."
}

cmd_uninstall() {
  echo ""
  echo "  This will remove:"
  echo "    • CLI symlink at $BIN_TARGET"
  echo "    • ClawFlows section from AGENTS.md"
  echo "    • Scheduler cron job"
  echo ""
  echo "  Your created workflows in $CREATED_DIR/ will NOT be deleted."
  echo "  The repo at $CLAWFLOWS_DIR/ will NOT be deleted."
  echo ""
  printf "  Are you sure? [y/N] "
  read -r confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    echo "  Cancelled."
    return
  fi

  if [ -L "$BIN_TARGET" ]; then
    rm -f "$BIN_TARGET"
    echo "  Removed $BIN_TARGET"
  fi

  if [ -f "$AGENTS_MD" ] && grep -qF "$START_MARKER" "$AGENTS_MD"; then
    local tmpfile
    tmpfile="$(mktemp)"
    awk -v start="$START_MARKER" -v end="$END_MARKER" '
      $0 == start { skip=1; next }
      $0 == end   { skip=0; next }
      !skip       { print }
    ' "$AGENTS_MD" > "$tmpfile"
    mv "$tmpfile" "$AGENTS_MD"
    echo "  Removed ClawFlows section from AGENTS.md"
  fi

  local oc
  oc="$(_find_openclaw)"
  if [ -n "$oc" ]; then
    "$oc" cron remove --name "clawflows-scheduler" </dev/null >/dev/null 2>&1 || true
    echo "  Removed scheduler cron"
  fi

  echo ""
  echo "  Done. To fully remove, also run:"
  echo "    rm -rf $CLAWFLOWS_DIR"
  echo ""
  echo "  ⚠️  Warning: This will delete any workflows you created."
  echo "     Back up $CREATED_DIR/ first if you want to keep them."
  echo ""
}

cmd_doctor() {
  echo ""
  echo "  🩺 ClawFlows Doctor"
  echo ""

  local issues=0

  # Check each clawflows.json entry points to a real WORKFLOW.md
  python3 -c "
import sys, json
data = json.load(sys.stdin)
for entry in data:
    print(entry.get('name', '') + '|' + entry.get('path', ''))
" <<< "$(_json_read)" 2>/dev/null | while IFS='|' read -r name path; do
    [ -n "$name" ] || continue
    local wf_file="$CLAWFLOWS_DIR/clawflows/$path/WORKFLOW.md"
    if [ ! -f "$wf_file" ]; then
      echo "  ❌ $name: WORKFLOW.md missing at $wf_file"
      issues=$((issues + 1))
    fi
  done

  # Check for duplicate names in clawflows.json
  local dupes
  dupes="$(python3 -c "
import sys, json
data = json.load(sys.stdin)
names = [e.get('name') for e in data]
seen = set()
for n in names:
    if n in seen:
        print(n)
    seen.add(n)
" <<< "$(_json_read)" 2>/dev/null)"
  if [ -n "$dupes" ]; then
    echo "$dupes" | while read -r dupe; do
      echo "  ⚠️  Duplicate clawflows.json entry: $dupe"
      issues=$((issues + 1))
    done
  fi

  # Check for orphaned workflows (on disk but not in clawflows.json)
  local orphaned=0
  for dir in "$CREATED_DIR"/*/; do
    [ -d "$dir" ] || continue
    local name
    name="$(basename "$dir")"
    [ "$name" = ".gitkeep" ] && continue
    # Not an issue, just informational — orphaned means available but not enabled
  done

  if [ "$issues" -eq 0 ]; then
    echo "  ✅ All workflows look healthy!"
    echo "     All clawflows.json entries point to valid files."
  else
    echo ""
    echo "  Found $issues issue(s)."
  fi
  echo ""
}

cmd_sync() {
  local block
  block="$(_build_block)"

  if [ ! -f "$AGENTS_MD" ]; then
    echo "note: AGENTS.md not found at $AGENTS_MD (skipping sync)"
    return 0
  fi

  if grep -qF "$START_MARKER" "$AGENTS_MD"; then
    _replace_block "$block"
  else
    printf "\n%s\n" "$block" >> "$AGENTS_MD"
  fi

  echo "synced AGENTS.md"
}

# ── Block builder ───────────────────────────────────────────────────────────

_build_block() {
  local lines=()

  lines+=("$START_MARKER")
  lines+=("## ClawFlows")
  lines+=("")
  lines+=("Workflow automation. When the user asks for something that matches an enabled workflow, run it.")
  lines+=("")
  lines+=("### Running a Workflow")
  lines+=("1. Match the user's request to a workflow in the Enabled Workflows list below")
  lines+=("2. Run \`clawflows run <name>\` — it auto-enables, reads WORKFLOW.md, logs the run, and invokes you to follow the steps")
  lines+=("")
  lines+=("### After Enabling or Creating a Workflow")
  lines+=("Read the WORKFLOW.md and check what services it references (\`**X skill**\` patterns like \`**email skill**\`, \`**calendar skill**\`). For each:")
  lines+=("- Check if you have access to it")
  lines+=("- If **essential** and missing: tell the user and offer to set it up")
  lines+=("- If **optional**: mention it's available for a better experience")
  lines+=("- Keep it brief — don't list services they already have")
  lines+=("")
  lines+=("### References")
  lines+=("- \`clawflows --help\` — all CLI commands")
  lines+=("- \`clawflows list\` — all workflows + paths")
  lines+=("- \`$CLAWFLOWS_DIR/system/AGENT.md\` — agent reference guide (install, sync, sharing)")
  lines+=("- \`$CLAWFLOWS_DIR/docs/creating-workflows.md\` — read this BEFORE creating a workflow")
  lines+=("- **Never edit \`clawflows.json\` directly** — always use CLI commands")
  lines+=("")
  lines+=("If the user asks for something that sounds like a workflow but no match fits, run \`clawflows list\` for a broader search, then offer to create one.")
  lines+=("")

  local has_enabled=false
  local entries=()

  # Read enabled workflows from clawflows.json
  local clawflows_entries
  clawflows_entries="$(python3 -c "
import sys, json
data = json.load(sys.stdin)
for entry in data:
    name = entry.get('name', '')
    path = entry.get('path', '')
    print(name + '|' + path)
" <<< "$(_json_read)" 2>/dev/null)"

  while IFS='|' read -r name path; do
    [ -n "$name" ] || continue
    local wf_file="$CLAWFLOWS_DIR/clawflows/$path/WORKFLOW.md"
    [ -f "$wf_file" ] || continue

    local desc
    desc="$(get_field "$wf_file" description)"
    entries+=("- **$name**: $desc")
    has_enabled=true
  done <<< "$clawflows_entries"

  if $has_enabled; then
    lines+=("### Enabled Workflows")
    lines+=("When the user asks for any of these, run \`clawflows run <name>\`.")
    for entry in "${entries[@]}"; do
      lines+=("$entry")
    done
  else
    lines+=("No workflows enabled yet. Run \`clawflows list\` to see what's available.")
  fi

  lines+=("$END_MARKER")

  printf '%s\n' "${lines[@]}"
}

_replace_block() {
  local new_block="$1"
  local tmpfile blockfile
  tmpfile="$(mktemp)"
  blockfile="$(mktemp)"

  printf '%s\n' "$new_block" > "$blockfile"

  awk -v start="$START_MARKER" -v end="$END_MARKER" -v bf="$blockfile" '
    $0 == start { while ((getline line < bf) > 0) print line; close(bf); skip=1; next }
    $0 == end   { skip=0; next }
    !skip       { print }
  ' "$AGENTS_MD" > "$tmpfile"

  mv "$tmpfile" "$AGENTS_MD"
  rm -f "$blockfile"
}

cmd_backup() {
  local filename="${1:-}"
  local timestamp
  timestamp="$(date +%Y-%m-%d-%H%M%S)"

  if [ -z "$filename" ]; then
    filename="clawflows-$timestamp.tar.gz"
  elif [[ "$filename" != *.tar.gz ]]; then
    filename="$filename.tar.gz"
  fi

  mkdir -p "$BACKUP_DIR"

  local tmpdir
  tmpdir="$(mktemp -d)"

  # Copy created workflows
  if [ -d "$CREATED_DIR" ] && [ "$(ls -A "$CREATED_DIR" 2>/dev/null | grep -v '.gitkeep')" ]; then
    mkdir -p "$tmpdir/created"
    for wf in "$CREATED_DIR"/*/; do
      [ -d "$wf" ] || continue
      local name="$(basename "$wf")"
      [ "$name" = ".gitkeep" ] && continue
      # Remove trailing slash to copy the directory itself, not just contents
      cp -r "${wf%/}" "$tmpdir/created/"
    done
  else
    mkdir -p "$tmpdir/created"
  fi

  # Copy clawflows.json
  if [ -f "$CLAWFLOWS_JSON" ]; then
    cp "$CLAWFLOWS_JSON" "$tmpdir/clawflows.json"
  fi

  # Copy runs.jsonl (run history)
  local runs_file="$CLAWFLOWS_DIR/system/runs.jsonl"
  if [ -f "$runs_file" ]; then
    cp "$runs_file" "$tmpdir/runs.jsonl"
  fi

  # Save enabled workflows list (backward compat)
  : > "$tmpdir/enabled-workflows.txt"
  python3 -c "
import sys, json
data = json.load(sys.stdin)
for entry in data:
    print(entry.get('name', ''))
" <<< "$(_json_read)" 2>/dev/null >> "$tmpdir/enabled-workflows.txt"

  # Create archive
  local archive_items="created enabled-workflows.txt"
  [ -f "$tmpdir/clawflows.json" ] && archive_items="$archive_items clawflows.json"
  [ -f "$tmpdir/runs.jsonl" ] && archive_items="$archive_items runs.jsonl"
  tar -czf "$BACKUP_DIR/$filename" -C "$tmpdir" $archive_items
  rm -rf "$tmpdir"

  # Count what we backed up
  local created_count=0
  for wf in "$CREATED_DIR"/*/; do
    [ -d "$wf" ] || continue
    [ "$(basename "$wf")" = ".gitkeep" ] && continue
    ((created_count++)) || true
  done

  local enabled_count
  enabled_count="$(python3 -c "import sys,json; print(len(json.load(sys.stdin)))" <<< "$(_json_read)" 2>/dev/null)"

  echo ""
  echo "  Backup created"
  echo ""
  echo "    Created workflows: $created_count"
  echo "    Enabled workflows: $enabled_count"
  echo ""
  echo "    $BACKUP_DIR/$filename"
  echo ""
}

cmd_restore() {
  local file="${1:-}"

  # List available backups if none specified
  if [ -z "$file" ]; then
    if [ ! -d "$BACKUP_DIR" ] || [ -z "$(ls -A "$BACKUP_DIR" 2>/dev/null)" ]; then
      echo ""
      echo "  No backups found in $BACKUP_DIR"
      echo "  Run 'clawflows backup' to create one."
      echo ""
      return 1
    fi

    echo ""
    echo "  Available backups:"
    echo ""
    local i=1
    local backups=()
    # Sort newest first (reverse alphabetical since filenames have timestamps)
    for f in $(ls -r "$BACKUP_DIR"/*.tar.gz 2>/dev/null); do
      [ -f "$f" ] || continue
      backups+=("$f")
      local name="$(basename "$f")"
      if [ $i -eq 1 ]; then
        echo "    $i. $name (latest)"
      else
        echo "    $i. $name"
      fi
      ((i++))
    done

    if [ ${#backups[@]} -eq 0 ]; then
      echo "  No backups found."
      echo ""
      return 1
    fi

    echo ""
    printf "  Restore which backup? [1]: "
    read -r choice
    choice="${choice:-1}"

    if [[ ! "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt ${#backups[@]} ]; then
      echo "  Cancelled."
      return 1
    fi

    file="${backups[$((choice-1))]}"
  fi

  # Handle "latest"
  if [ "$file" = "latest" ]; then
    file="$(ls -r "$BACKUP_DIR"/*.tar.gz 2>/dev/null | head -1)"
    [ -n "$file" ] || die "no backups found"
  fi

  # Resolve relative path
  if [ ! -f "$file" ] && [ -f "$BACKUP_DIR/$file" ]; then
    file="$BACKUP_DIR/$file"
  fi

  [ -f "$file" ] || die "backup not found: $file"

  echo ""
  echo "  Restoring from $(basename "$file")..."

  local tmpdir
  tmpdir="$(mktemp -d)"
  tar -xzf "$file" -C "$tmpdir"

  # Restore created workflows (support old backups with custom/ dir)
  local restored=0
  local skipped=0
  local restore_src="$tmpdir/created"
  [ -d "$restore_src" ] || restore_src="$tmpdir/custom"
  if [ -d "$restore_src" ]; then
    for wf in "$restore_src"/*/; do
      [ -d "$wf" ] || continue
      local name="$(basename "$wf")"
      [ "$name" = ".gitkeep" ] && continue

      # Validate workflow name to prevent path traversal
      # Check for newlines first (same logic as validate_workflow_name)
      case "$name" in
        *$'\n'*)
          echo "  Warning: skipping invalid workflow name in backup: '$name' (contains newline)"
          continue
          ;;
      esac
      
      if ! printf '%s' "$name" | grep -qE '^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$'; then
        echo "  Warning: skipping invalid workflow name in backup: '$name'"
        continue
      fi

      if [ -d "$CREATED_DIR/$name" ]; then
        ((skipped++)) || true
      else
        # Remove trailing slash to copy the directory itself, not just contents
        cp -r "${wf%/}" "$CREATED_DIR/"
        ((restored++)) || true
      fi
    done
  fi

  # Re-enable workflows
  local enabled=0
  if [ -f "$tmpdir/clawflows.json" ]; then
    # Merge clawflows.json from backup
    python3 -c "
import sys, json
backup = json.load(open('$tmpdir/clawflows.json'))
try:
    current = json.load(open('$CLAWFLOWS_JSON'))
except:
    current = []
current_names = {e.get('name') for e in current}
for entry in backup:
    if entry.get('name') not in current_names:
        current.append(entry)
        print(entry.get('name', ''))
with open('$CLAWFLOWS_JSON', 'w') as f:
    json.dump(current, f, indent=2)
" 2>/dev/null | while IFS= read -r name; do
      [ -n "$name" ] && enabled=$((enabled + 1))
    done
    enabled="$(python3 -c "
import json
backup = json.load(open('$tmpdir/clawflows.json'))
try:
    current = json.load(open('$CLAWFLOWS_JSON'))
except:
    current = []
current_names_before = set()
print(len(current) - len(current_names_before))
" 2>/dev/null || echo "0")"
    # Just count how many we added
    enabled="$(python3 -c "
import json
try:
    current = json.load(open('$CLAWFLOWS_JSON'))
except:
    current = []
print(len(current))
" 2>/dev/null || echo "0")"
  elif [ -f "$tmpdir/enabled-workflows.txt" ]; then
    # Legacy: re-enable from text file
    while IFS= read -r name || [ -n "$name" ]; do
      [ -z "$name" ] && continue

      # Validate workflow name to prevent path traversal
      case "$name" in
        *$'\n'*)
          echo "  Warning: skipping invalid workflow name in enabled list: '$name' (contains newline)"
          continue
          ;;
      esac

      if ! printf '%s' "$name" | grep -qE '^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$'; then
        echo "  Warning: skipping invalid workflow name in enabled list: '$name'"
        continue
      fi

      if _json_is_enabled "$name"; then
        continue  # already enabled
      fi
      local source_dir
      source_dir="$(_find_workflow "$name")"
      if [ -n "$source_dir" ]; then
        cmd_enable "$name" >/dev/null 2>&1
        ((enabled++)) || true
      fi
    done < "$tmpdir/enabled-workflows.txt"
  fi

  # Restore runs.jsonl if present (only if no existing runs file, to avoid clobbering newer history)
  local runs_restored=0
  local runs_file="$CLAWFLOWS_DIR/system/runs.jsonl"
  if [ -f "$tmpdir/runs.jsonl" ] && [ ! -f "$runs_file" ]; then
    cp "$tmpdir/runs.jsonl" "$runs_file"
    runs_restored=1
  fi

  rm -rf "$tmpdir"

  # Sync AGENTS.md if we enabled anything
  if [ $enabled -gt 0 ]; then
    cmd_sync >/dev/null 2>&1 || true
  fi

  echo ""
  echo "  Restored $restored workflow(s)"
  [ $skipped -gt 0 ] && echo "  Skipped $skipped (already exist)"
  echo "  Enabled $enabled workflow(s)"
  [ $runs_restored -gt 0 ] && echo "  Restored runs.jsonl history"
  echo ""
}

cmd_validate() {
  local name="$1"
  validate_workflow_name "$name"
  local wf_dir wf_file errors=0

  # Find the workflow
  wf_dir="$(_find_workflow "$name")"
  [ -n "$wf_dir" ] || die "workflow '$name' not found"

  wf_file="$wf_dir/WORKFLOW.md"
  [ -f "$wf_file" ] || die "WORKFLOW.md not found at $wf_file"

  echo ""
  echo "  Validating $name..."
  echo ""

  # Check frontmatter exists
  if ! head -1 "$wf_file" | grep -q '^---$'; then
    echo "  ✗ Missing frontmatter (file must start with ---)"
    errors=1
  fi

  # Check required fields
  local field_name field_emoji field_desc
  field_name="$(get_field "$wf_file" name)"
  field_emoji="$(get_field "$wf_file" emoji)"
  field_desc="$(get_field "$wf_file" description)"

  if [ -z "$field_name" ]; then
    echo "  ✗ Missing required field: name"
    errors=1
  else
    echo "  ✓ name: $field_name"
  fi

  if [ -z "$field_emoji" ]; then
    echo "  ✗ Missing required field: emoji"
    errors=1
  else
    echo "  ✓ emoji: $field_emoji"
  fi

  if [ -z "$field_desc" ]; then
    echo "  ✗ Missing required field: description"
    errors=1
  else
    echo "  ✓ description: $field_desc"
  fi

  echo ""

  if [ $errors -eq 0 ]; then
    echo "  ✓ Workflow is valid!"
    echo ""
    return 0
  else
    echo "  ✗ Validation failed"
    echo ""
    return 1
  fi
}


cmd_share() {
  local name="${1:-}"
  local copy_flag="${2:-}"

  [ -n "$name" ] || die "usage: clawflows share <name>"

  # Handle --copy as first or second arg BEFORE validation
  if [ "$name" = "--copy" ]; then
    die "usage: clawflows share <name> [--copy]"
  fi

  validate_workflow_name "$name"

  local source_dir
  source_dir="$(_find_workflow "$name")"
  [ -n "$source_dir" ] || die "workflow '$name' not found"

  local wf_file="$source_dir/WORKFLOW.md"
  [ -f "$wf_file" ] || die "WORKFLOW.md not found at $wf_file"

  local emoji desc
  emoji="$(get_field "$wf_file" emoji)"
  desc="$(get_field "$wf_file" description)"

  local share_text="${emoji:+$emoji }$name
${desc:+$desc

}Get it: curl -fsSL https://raw.githubusercontent.com/nikilster/clawflows/main/system/install.sh | bash && clawflows enable $name"

  if [ "$copy_flag" = "--copy" ]; then
    if command -v pbcopy >/dev/null 2>&1; then
      printf '%s' "$share_text" | pbcopy
      echo "Copied to clipboard!"
    else
      echo "$share_text"
      echo ""
      echo "(pbcopy not available — text printed above)"
    fi
  else
    echo "$share_text"
  fi
}

cmd_import() {
  local url="${1:-}"

  [ -n "$url" ] || die "usage: clawflows import <url>"

  # Validate HTTPS
  case "$url" in
    https://*) ;;
    http://*)  die "only HTTPS URLs are supported (got HTTP)" ;;
    *)         die "invalid URL: $url (must start with https://)" ;;
  esac

  # Normalize GitHub blob URLs to raw
  # https://github.com/user/repo/blob/branch/path -> https://raw.githubusercontent.com/user/repo/branch/path
  local raw_url="$url"
  if echo "$raw_url" | grep -q '^https://github\.com/.*/blob/'; then
    raw_url="$(echo "$raw_url" | sed 's|^https://github\.com/\([^/]*/[^/]*\)/blob/|https://raw.githubusercontent.com/\1/|')"
  fi

  # Normalize gist URLs to raw
  # https://gist.github.com/user/id -> https://gist.githubusercontent.com/user/id/raw
  if echo "$raw_url" | grep -q '^https://gist\.github\.com/'; then
    raw_url="$(echo "$raw_url" | sed 's|^https://gist\.github\.com/|https://gist.githubusercontent.com/|')"
    # Append /raw if not already present
    case "$raw_url" in
      */raw|*/raw/) ;;
      *) raw_url="${raw_url}/raw" ;;
    esac
  fi

  # Download to temp file
  local tmpfile
  tmpfile="$(mktemp)"
  trap "rm -f '$tmpfile'" EXIT

  if ! curl -fsSL "$raw_url" -o "$tmpfile" 2>/dev/null; then
    rm -f "$tmpfile"
    die "failed to download from $raw_url"
  fi

  # Validate frontmatter
  local wf_name wf_emoji wf_desc
  wf_name="$(get_field "$tmpfile" name)"
  wf_emoji="$(get_field "$tmpfile" emoji)"
  wf_desc="$(get_field "$tmpfile" description)"

  [ -n "$wf_name" ] || { rm -f "$tmpfile"; die "downloaded file is missing required 'name' field in frontmatter"; }
  [ -n "$wf_desc" ] || { rm -f "$tmpfile"; die "downloaded file is missing required 'description' field in frontmatter"; }

  # Show what was downloaded and warn about external source
  echo ""
  echo "  ${wf_emoji:+$wf_emoji }$wf_name"
  [ -n "$wf_desc" ] && echo "  $wf_desc"
  echo ""
  echo "  ! Downloaded from: $url"
  echo "  ! Review workflows before enabling — they run with your agent's permissions."
  echo ""
  printf "  Save this workflow? [y/N] "
  read -r save_confirm
  if [ "$save_confirm" != "y" ] && [ "$save_confirm" != "Y" ]; then
    echo "  Cancelled."
    rm -f "$tmpfile"
    return
  fi

  # Check for conflicts
  local dest_dir="$CREATED_DIR/$wf_name"
  if [ -d "$dest_dir" ]; then
    printf "  workflow '$wf_name' already exists in created/. Overwrite? [y/N] "
    read -r confirm
    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
      echo "  Cancelled."
      rm -f "$tmpfile"
      return
    fi
  fi

  # Save to created/
  mkdir -p "$dest_dir"
  cp "$tmpfile" "$dest_dir/WORKFLOW.md"
  rm -f "$tmpfile"
  trap - EXIT

  echo "  Saved to created/$wf_name"

  # Offer to enable
  printf "  Enable this workflow? [Y/n] "
  read -r enable_confirm
  if [ "$enable_confirm" != "n" ] && [ "$enable_confirm" != "N" ]; then
    cmd_enable "$wf_name"
  else
    echo ""
    echo "  Enable later with: clawflows enable $wf_name"
    echo ""
  fi
}

cmd_run() {
  local name="$1"
  validate_workflow_name "$name"
  local wf_file

  # Find the workflow - check clawflows.json first, then disk
  if _json_is_enabled "$name"; then
    local reg_path
    reg_path="$(python3 -c "import sys,json; [print(e['path']) for e in json.load(sys.stdin) if e.get('name')=='$name']" <<< "$(_json_read)" 2>/dev/null)"
    wf_file="$CLAWFLOWS_DIR/clawflows/$reg_path/WORKFLOW.md"
  elif [ -n "$(_find_workflow "$name")" ]; then
    # Auto-enable if not enabled
    echo "Enabling $name..."
    cmd_enable "$name"
    local reg_path
    reg_path="$(python3 -c "import sys,json; [print(e['path']) for e in json.load(sys.stdin) if e.get('name')=='$name']" <<< "$(_json_read)" 2>/dev/null)"
    wf_file="$CLAWFLOWS_DIR/clawflows/$reg_path/WORKFLOW.md"
  else
    die "workflow '$name' not found"
  fi

  [ -f "$wf_file" ] || die "WORKFLOW.md not found at $wf_file"

  local runs_file="$CLAWFLOWS_DIR/system/runs.jsonl"

  # Run via openclaw if available
  local oc
  oc="$(_find_openclaw)"
  if [ -n "$oc" ]; then
    echo "Running $name — check your chat with your agent for results."
    echo ""
    "$oc" agent --agent main -m "Run the $name workflow by following $wf_file.

After running, append one JSONL line to $runs_file describing what you did:

cat >> $runs_file << 'EOF'
{\"timestamp\":\"<ISO timestamp now>\",\"workflow\":\"$name\",\"trigger\":\"manual\",\"output\":\"<what you actually did>\"}
EOF

The 'output' field must describe the concrete user-facing actions you took — name channels, targets, and what was sent/changed. Examples:
- \"Sent morning briefing to Telegram 345754343: 65F NYC, 3 meetings, top goal ship clawflows v2.\"
- \"Archived 8 junk emails, flagged 2 urgent (from Stripe, from landlord). No replies sent.\"
- \"Turned off Lutron main lights, set Hue living room to dim red, started Sonos meditation playlist at volume 3.\"
- \"No nudge sent. User on 'fix dave' timer, exercised today, aligned with goals.\"
- \"Blocked: browser tool unavailable. No DoorDash check performed.\"

Do NOT write vague summaries like 'ran workflow'. Say what was sent, what was changed, and to whom."
  else
    echo ""
    echo "  ✓ Workflow ready: $name"
    echo ""
    echo "  To run it, tell your agent:"
    echo ""
    echo "    Run $name"
    echo ""
  fi
}

# ── Logs ──────────────────────────────────────────────────────────────────────

cmd_logs() {
  local filter_name="${1:-}"
  [ -n "$filter_name" ] && validate_workflow_name "$filter_name"
  local filter_date="${2:-}"
  local runs_file="$CLAWFLOWS_DIR/system/runs.jsonl"

  if [ ! -f "$runs_file" ]; then
    echo "No runs yet."
    return
  fi

  python3 - "$runs_file" "$filter_name" "$filter_date" <<'PY'
import json, sys
runs_file, filter_name, filter_date = sys.argv[1:4]
max_entries = 20

with open(runs_file) as f:
    lines = [l for l in f.readlines() if l.strip()]

# Newest first
entries = []
for line in reversed(lines):
    try:
        e = json.loads(line)
    except json.JSONDecodeError:
        continue
    if filter_name and e.get("workflow") != filter_name:
        continue
    if filter_date and not e.get("timestamp", "").startswith(filter_date):
        continue
    entries.append(e)
    if len(entries) >= max_entries:
        break

if not entries:
    if filter_name:
        print(f"No runs found for '{filter_name}'.")
    else:
        print("No runs yet.")
    sys.exit(0)

for e in entries:
    ts = e.get("timestamp", "?")
    wf = e.get("workflow", "?")
    trigger = e.get("trigger", "?")
    slot = e.get("scheduled_time", "")
    slot_str = f" @ {slot}" if slot else ""
    print(f"─── {ts} {wf} [{trigger}{slot_str}] ───")
    out = e.get("output", "").strip()
    print(out if out else "(no output recorded)")
    print()
PY
}


# ── Web Config ──────────────────────────────────────────────────────────────
HUB_URL="${CLAWFLOWS_HUB_URL:-https://clawflows.ai}"
HUB_DIR="$HOME/.clawflows"
HUB_TOKEN_FILE="$HUB_DIR/token"
_hub_ensure_dir() {
  mkdir -p "$HUB_DIR"
}

_hub_get_token() {
  if [ -f "$HUB_TOKEN_FILE" ]; then
    cat "$HUB_TOKEN_FILE"
  fi
}

_hub_save_token() {
  _hub_ensure_dir
  printf '%s' "$1" > "$HUB_TOKEN_FILE"
  chmod 600 "$HUB_TOKEN_FILE"
}

# ── Web Commands ────────────────────────────────────────────────────────────

cmd_web_login() {
  _hub_ensure_dir

  # If a token is passed directly, save it and verify
  if [ -n "${1:-}" ]; then
    local token="$1"
    _hub_save_token "$token"

    # Verify the token works
    local response
    response="$(curl -sf -X POST "$HUB_URL/api/sync" \
      -H "Authorization: Bearer $token" \
      -H "Content-Type: application/json" \
      -d '{"workflows":[]}')" || {
      rm -f "$HUB_TOKEN_FILE"
      die "Invalid token. Please check and try again."
    }

    echo ""
    echo "  ✅ Logged in successfully!"
    echo ""
    echo "  Run 'clawflows sync' to push your workflows."
    echo ""
    return
  fi

  echo ""
  echo "  To log in, sign up at clawflows.ai and you'll get a login token."
  echo ""
  echo "    $HUB_URL"
  echo ""
  echo "  Then run:"
  echo ""
  echo "    clawflows login <your-token>"
  echo ""

  # Try to open the site
  open "$HUB_URL" 2>/dev/null || true
}

cmd_web_logout() {
  if [ -f "$HUB_TOKEN_FILE" ]; then
    rm -f "$HUB_TOKEN_FILE"
    echo "Logged out from ClawFlows Web."
  else
    echo "Not logged in."
  fi
}

cmd_web_whoami() {
  local token
  token="$(_hub_get_token)"
  [ -n "$token" ] || die "Not logged in. Run: clawflows login"

  # Quick check — try to sync with empty data to verify token
  local response
  response="$(curl -sf -X POST "$HUB_URL/api/sync" \
    -H "Authorization: Bearer $token" \
    -H "Content-Type: application/json" \
    -d '{"workflows":[]}')" || die "Could not reach ClawFlows.ai or token is invalid"

  local synced
  synced="$(printf '%s' "$response" | grep -o '"synced":true')"
  if [ -n "$synced" ]; then
    local username
    username="$(printf '%s' "$response" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("agent",{}).get("username",""))' 2>/dev/null)" || true
    if [ -n "$username" ]; then
      echo "Logged in as @$username"
    else
      echo "Logged in. Token is valid."
    fi
  else
    echo "Token may be invalid. Try: clawflows login"
  fi
}

cmd_web_sync() {
  local token
  token="$(_hub_get_token)"
  [ -n "$token" ] || die "Not logged in. Run: clawflows login"

  # One-time migration: rename workflows/ to clawflows/
  local old_workflows_dir="$CLAWFLOWS_DIR/workflows"
  if [ -d "$old_workflows_dir" ] && [ ! -d "$CLAWFLOWS_DIR/clawflows" ]; then
    mv "$old_workflows_dir" "$CLAWFLOWS_DIR/clawflows"
    echo "  Migrated workflows/ to clawflows/"
  elif [ -d "$old_workflows_dir" ] && [ -d "$CLAWFLOWS_DIR/clawflows" ]; then
    for sub in available enabled; do
      if [ -d "$old_workflows_dir/$sub" ]; then
        cp -rn "$old_workflows_dir/$sub/"* "$CLAWFLOWS_DIR/clawflows/$sub/" 2>/dev/null || true
      fi
    done
    rm -rf "$old_workflows_dir"
    echo "  Migrated workflows/ to clawflows/"
  fi

  # One-time migration: rename custom/ to created/ (check all old locations)
  for old_custom_dir in "$CLAWFLOWS_DIR/clawflows/available/custom" "$CLAWFLOWS_DIR/clawflows/custom"; do
    if [ -d "$old_custom_dir" ]; then
      mkdir -p "$CREATED_DIR"
      for wf in "$old_custom_dir"/*/; do
        [ -d "$wf" ] || continue
        local wf_name
        wf_name="$(basename "$wf")"
        [ "$wf_name" = ".gitkeep" ] && continue
        if [ ! -d "$CREATED_DIR/$wf_name" ]; then
          mv "$wf" "$CREATED_DIR/$wf_name"
        fi
      done
      rm -rf "$old_custom_dir"
      echo "  Migrated custom/ to created/"
    fi
  done

  # One-time migration: move available/ contents up to clawflows/
  local old_available_dir="$CLAWFLOWS_DIR/clawflows/available"
  if [ -d "$old_available_dir" ]; then
    # Move created/ up if it exists under available/
    if [ -d "$old_available_dir/created" ]; then
      mkdir -p "$CREATED_DIR"
      for wf in "$old_available_dir/created"/*/; do
        [ -d "$wf" ] || continue
        local wf_name
        wf_name="$(basename "$wf")"
        [ "$wf_name" = ".gitkeep" ] && continue
        if [ ! -d "$CREATED_DIR/$wf_name" ]; then
          mv "$wf" "$CREATED_DIR/$wf_name"
        fi
      done
      rm -rf "$old_available_dir/created"
    fi
    # Move installed/ up if it exists under available/
    if [ -d "$old_available_dir/installed" ]; then
      mkdir -p "$INSTALLED_DIR"
      for agent_dir in "$old_available_dir/installed"/*/; do
        [ -d "$agent_dir" ] || continue
        local agent_id
        agent_id="$(basename "$agent_dir")"
        if [ ! -d "$INSTALLED_DIR/$agent_id" ]; then
          mv "$agent_dir" "$INSTALLED_DIR/$agent_id"
        else
          for wf in "$agent_dir"*/; do
            [ -d "$wf" ] || continue
            local wf_name
            wf_name="$(basename "$wf")"
            if [ ! -d "$INSTALLED_DIR/$agent_id/$wf_name" ]; then
              mv "$wf" "$INSTALLED_DIR/$agent_id/$wf_name"
            fi
          done
        fi
      done
      rm -rf "$old_available_dir/installed"
    fi
    # Move community/ to installed if still present
    if [ -d "$old_available_dir/community" ]; then
      local community_dir="$old_available_dir/community"
      for wf in "$community_dir"/*/; do
        [ -d "$wf" ] || continue
        local wf_name
        wf_name="$(basename "$wf")"
        local dest="$INSTALLED_DIR/1/$wf_name"
        if [ ! -d "$dest" ]; then
          mkdir -p "$dest"
          cp -r "$wf"* "$dest/" 2>/dev/null || true
        fi
      done
      rm -rf "$community_dir"
    fi
    # Clean up available/ if empty
    rmdir "$old_available_dir" 2>/dev/null || true
    echo "  Migrated available/ directory structure"
  fi

  # One-time migration: build clawflows.json from symlinks in enabled/
  local old_enabled_dir="$CLAWFLOWS_DIR/clawflows/enabled"
  if [ -d "$old_enabled_dir" ] && [ ! -f "$CLAWFLOWS_JSON" ]; then
    echo "  Building clawflows.json from enabled symlinks..."
    local now
    now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    local migration_entries="["
    local mig_first=true

    for link in "$old_enabled_dir"/*; do
      [ -e "$link" ] || [ -L "$link" ] || continue
      local wf_name
      wf_name="$(basename "$link")"
      [ "$wf_name" = ".gitkeep" ] && continue

      # Resolve symlink target
      local target=""
      if [ -L "$link" ]; then
        target="$(readlink "$link")"
      fi

      local source rel_path schedule agent_id username version
      schedule=""

      # Determine source from target path
      if [ -d "$CREATED_DIR/$wf_name" ]; then
        source="created"
        rel_path="created/$wf_name"
        if [ -f "$CREATED_DIR/$wf_name/WORKFLOW.md" ]; then
          schedule="$(get_field "$CREATED_DIR/$wf_name/WORKFLOW.md" schedule)"
        fi
      else
        # Check installed/
        local found_installed=false
        if [ -d "$INSTALLED_DIR" ]; then
          for agent_dir in "$INSTALLED_DIR"/*/; do
            [ -d "$agent_dir" ] || continue
            if [ -d "$agent_dir$wf_name" ]; then
              agent_id="$(basename "$agent_dir")"
              source="installed"
              rel_path="installed/$agent_id/$wf_name"
              if [ -f "$agent_dir$wf_name/WORKFLOW.md" ]; then
                schedule="$(get_field "$agent_dir$wf_name/WORKFLOW.md" schedule)"
              fi
              # Read username from .agent.json
              username=""
              if [ -f "$agent_dir.agent.json" ]; then
                username="$(python3 -c 'import sys,json; print(json.load(sys.stdin).get("username",""))' < "$agent_dir.agent.json" 2>/dev/null)"
              fi
              # Read version from installed.json
              version="1"
              if [ -f "$HOME/.clawflows/installed.json" ]; then
                version="$(python3 -c "
import sys, json
d = json.load(sys.stdin)
v = d.get('$agent_id/$wf_name', {}).get('version', 1)
print(v)
" < "$HOME/.clawflows/installed.json" 2>/dev/null || echo "1")"
              fi
              found_installed=true
              break
            fi
          done
        fi
        if ! $found_installed; then
          # Workflow on disk somewhere but can't determine — skip
          continue
        fi
      fi

      if [ "$mig_first" = true ]; then
        mig_first=false
      else
        migration_entries="$migration_entries,"
      fi

      if [ "$source" = "installed" ]; then
        migration_entries="$migration_entries{\"name\":\"$wf_name\",\"schedule\":\"${schedule:-}\",\"path\":\"$rel_path\",\"source\":\"installed\",\"agent_id\":\"$agent_id\",\"username\":\"${username:-}\",\"version\":${version:-1},\"created_at\":\"$now\"}"
      else
        migration_entries="$migration_entries{\"name\":\"$wf_name\",\"schedule\":\"${schedule:-}\",\"path\":\"$rel_path\",\"source\":\"created\",\"created_at\":\"$now\"}"
      fi
    done

    migration_entries="$migration_entries]"
    printf '%s' "$migration_entries" | python3 -c "import sys,json; json.dump(json.load(sys.stdin), open('$CLAWFLOWS_JSON','w'), indent=2)" 2>/dev/null
    echo "  Built clawflows.json with $(python3 -c "import json; print(len(json.load(open('$CLAWFLOWS_JSON'))))" 2>/dev/null || echo "0") entries"
  fi

  # Clean up old enabled/ directory and .agent.json files
  if [ -d "$old_enabled_dir" ] && [ -f "$CLAWFLOWS_JSON" ]; then
    rm -rf "$old_enabled_dir"
    echo "  Removed old enabled/ directory"
  fi

  # Clean up old installed.json
  if [ -f "$HOME/.clawflows/installed.json" ] && [ -f "$CLAWFLOWS_JSON" ]; then
    rm -f "$HOME/.clawflows/installed.json"
  fi

  # Ensure clawflows.json exists
  if [ ! -f "$CLAWFLOWS_JSON" ]; then
    echo "[]" > "$CLAWFLOWS_JSON"
  fi

  echo "Syncing workflows to ClawFlows Web..."

  # Build the workflow list from created/
  local workflows_json="["
  local first=true
  local created_count=0

  # Sync all created workflows
  if [ -d "$CREATED_DIR" ]; then
    for dir in "$CREATED_DIR"/*/; do
      [ -d "$dir" ] || continue
      local wf_file="$dir/WORKFLOW.md"
      [ -f "$wf_file" ] || continue

      local name slug emoji desc category schedule visibility content content_hash
      name="$(basename "$dir")"
      slug="$name"
      emoji="$(get_field "$wf_file" emoji)"
      desc="$(get_field "$wf_file" description)"
      category="$(get_field "$wf_file" category)"
      schedule="$(get_field "$wf_file" schedule)"
      visibility="$(get_field "$wf_file" visibility)"

      # Skip no-sync workflows
      if [ "$visibility" = "no-sync" ]; then
        continue
      fi

      content="$(cat "$wf_file")"
      content_hash="$(shasum -a 256 "$wf_file" | cut -d' ' -f1)"

      # Get a display name from the frontmatter name field, falling back to slug
      local display_name
      display_name="$(get_field "$wf_file" name)"
      [ -n "$display_name" ] || display_name="$name"
      # Convert slug to title case for display
      display_name="$(echo "$display_name" | sed 's/-/ /g' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1')"

      if [ "$first" = true ]; then
        first=false
      else
        workflows_json="$workflows_json,"
      fi

      # Escape content for JSON
      local escaped_content
      escaped_content="$(printf '%s' "$content" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null || printf '%s' "$content" | sed 's/\\/\\\\/g;s/"/\\"/g;s/\t/\\t/g' | tr '\n' '\n' | sed ':a;N;$!ba;s/\n/\\n/g')"

      local visibility_json=""
      [ -n "$visibility" ] && visibility_json=",\"visibility\":\"$visibility\""

      workflows_json="$workflows_json{\"name\":\"$display_name\",\"slug\":\"$slug\",\"emoji\":\"${emoji:-🔧}\",\"description\":$(printf '%s' "$desc" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))'),\"category\":\"${category:-General}\",\"schedule\":$([ -n "$schedule" ] && printf '%s' "\"$schedule\"" || echo null)${visibility_json},\"content\":$escaped_content,\"content_hash\":\"$content_hash\"}"

      created_count=$((created_count + 1))
    done
  fi
  workflows_json="$workflows_json]"

  # Build run counts from system/runs/
  local run_counts="{}"
  if [ -d "$CLAWFLOWS_DIR/system/runs" ]; then
    local counts_json="{"
    local count_first=true
    for date_dir in "$CLAWFLOWS_DIR/system/runs"/*/; do
      [ -d "$date_dir" ] || continue
      for wf_dir in "$date_dir"*/; do
        [ -d "$wf_dir" ] || continue
        local wf_name
        wf_name="$(basename "$wf_dir")"
        local run_count
        run_count="$(find "$CLAWFLOWS_DIR/system/runs" -path "*/$wf_name/*" -type f 2>/dev/null | wc -l | tr -d ' ')"
        if [ "$count_first" = true ]; then
          count_first=false
        else
          counts_json="$counts_json,"
        fi
        counts_json="$counts_json\"$wf_name\":$run_count"
      done
    done
    counts_json="$counts_json}"
    run_counts="$counts_json"
  fi

  # Detect model from OpenClaw
  local profile_json="{}"
  local oc_model
  oc_model="$(openclaw models status --json 2>/dev/null | python3 -c 'import sys,json; print(json.load(sys.stdin).get("resolvedDefault",""))' 2>/dev/null)" || true

  # Detect environment (hardware, OS, timezone, CLI version)
  local env_json
  env_json="$(python3 -c '
import json, platform, subprocess
env = {"platform": platform.system()}
try:
    if platform.system() == "Darwin":
        sp = subprocess.run(["system_profiler", "SPHardwareDataType", "SPStorageDataType"], capture_output=True, text=True).stdout
        for line in sp.splitlines():
            k, _, v = line.partition(":")
            k, v = k.strip(), v.strip()
            if k == "Model Name" and v: env["device"] = v
            elif k == "Chip" and v: env["cpu"] = v
            elif k == "Total Number of Cores" and v: env["cores"] = v
            elif k == "Memory" and v: env["memory"] = v
            elif k == "Capacity" and v and "storage_bytes" not in env:
                try: env["storage_bytes"] = int(v.split("(")[1].split()[0].replace(",",""))
                except: pass
        ver = platform.mac_ver()[0]
        if ver: env["os_version"] = ver
        lnk = subprocess.run(["readlink", "/etc/localtime"], capture_output=True, text=True).stdout.strip()
        parts = lnk.split("zoneinfo/")
        if len(parts) > 1: env["timezone"] = parts[-1]
    else:
        try:
            with open("/sys/devices/virtual/dmi/id/product_name") as f:
                name = f.read().strip()
                if name and name != "System Product Name": env["device"] = name
        except: pass
        with open("/proc/cpuinfo") as f:
            cores = 0
            for line in f:
                if line.startswith("model name") and "cpu" not in env:
                    env["cpu"] = line.split(":")[1].strip()
                if line.startswith("processor"): cores += 1
            if cores: env["cores"] = str(cores)
        try:
            with open("/proc/meminfo") as f:
                for line in f:
                    if line.startswith("MemTotal"):
                        env["memory_kb"] = int(line.split()[1])
                        break
        except: pass
        try:
            import shutil
            env["storage_bytes"] = shutil.disk_usage("/").total
        except: pass
        env["os_version"] = platform.release()
        try:
            with open("/etc/timezone") as f:
                tz = f.read().strip()
                if tz: env["timezone"] = tz
        except: pass
except: pass
try:
    v = subprocess.run(["openclaw", "--version"], capture_output=True, text=True).stdout.strip()
    if v: env["openclaw_version"] = v.split()[-1] if " " in v else v
except: pass
print(json.dumps(env))
' 2>/dev/null)" || env_json="{}"

  # Build profile JSON with model + environment
  profile_json="$(python3 -c "
import json
p = {}
model = '''$oc_model'''
if model: p['model'] = model
env = json.loads('''$env_json''')
if env: p['environment'] = env
print(json.dumps(p))
" 2>/dev/null)" || profile_json="{}"

  # Read current clawflows.json to send to server
  local clawflows_json
  clawflows_json="$(_json_read)"

  # Collect capabilities from OpenClaw (skills + plugins)
  local capabilities_json="[]"
  if command -v openclaw >/dev/null 2>&1; then
    capabilities_json="$(python3 -c '
import json, subprocess, sys
caps = []
try:
    sk = json.loads(subprocess.run(["openclaw","skills","list","--eligible","--json"], capture_output=True, text=True).stdout)
    for s in sk.get("skills", []):
        caps.append({"slug":"skill/"+s["name"], "kind":"skill", "name":s["name"].replace("-"," ").title(), "emoji":s.get("emoji",""), "description":(s.get("description","") or "")[:200], "homepage_url":s.get("homepage"), "meta":{"source":s.get("source","")}})
except: pass
try:
    pl = json.loads(subprocess.run(["openclaw","plugins","list","--enabled","--json"], capture_output=True, text=True).stdout)
    for p in pl.get("plugins", []):
        caps.append({"slug":"plugin/"+p["id"], "kind":"plugin", "name":p["name"], "emoji":"", "description":(p.get("description","") or "")[:200], "meta":{"tool_names":p.get("toolNames",[])}})
except: pass
print(json.dumps(caps))
' 2>/dev/null)" || capabilities_json="[]"
  fi

  # Send to hub
  local response
  response="$(curl -sf -X POST "$HUB_URL/api/sync" \
    -H "Authorization: Bearer $token" \
    -H "Content-Type: application/json" \
    -d "{\"profile\":$profile_json,\"workflows\":$workflows_json,\"run_counts\":$run_counts,\"clawflows\":$clawflows_json,\"capabilities\":$capabilities_json}")" || die "Sync failed. Try: clawflows login"

  local total created updated
  total="$(printf '%s' "$response" | grep -o '"total":[0-9]*' | sed 's/"total"://')"
  created="$(printf '%s' "$response" | grep -o '"created":[0-9]*' | sed 's/"created"://')"
  updated="$(printf '%s' "$response" | grep -o '"updated":[0-9]*' | sed 's/"updated"://')"

  echo ""
  echo "  ✅ Synced $created_count clawflow(s) to web"
  [ "${created:-0}" -gt 0 ] && echo "     $created new" || true
  [ "${updated:-0}" -gt 0 ] && echo "     $updated updated" || true

  # Save server clawflows.json (only if server returned one)
  printf '%s' "$response" | python3 -c "
import sys, json
d = json.load(sys.stdin)
if 'clawflows' in d:
    with open('$CLAWFLOWS_JSON', 'w') as f:
        json.dump(d['clawflows'], f, indent=2)
" 2>/dev/null

  # Process updates from server (file writes and deletes)
  printf '%s' "$response" | python3 -c "
import sys, json, os

d = json.load(sys.stdin)
base = '$CLAWFLOWS_DIR/clawflows'
writes = 0
deletes = 0

for u in d.get('updates', []):
    action = u.get('action', '')
    path = u.get('path', '')

    if not action or not path:
        continue

    full_path = os.path.join(base, path)

    if action == 'write':
        content = u.get('content', '')
        os.makedirs(full_path, exist_ok=True)
        with open(os.path.join(full_path, 'WORKFLOW.md'), 'w') as f:
            f.write(content)
        writes += 1
    elif action == 'delete':
        import shutil
        if os.path.isdir(full_path):
            shutil.rmtree(full_path)
            deletes += 1

if writes: print(f'  ✅ {writes} clawflow(s) installed/updated from web')
if deletes: print(f'  🗑  {deletes} clawflow(s) removed')
" 2>/dev/null

  echo ""
}

_print_explore_results() {
  local response="$1"
  printf '%s' "$response" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for wf in d.get('workflows', []):
    emoji = wf.get('emoji', '🔧')
    name = wf.get('name', wf.get('slug', ''))
    desc = wf.get('description', '')
    schedule = wf.get('schedule', '')
    url = wf.get('url', '')
    line = f'    {emoji} {name}'
    if schedule:
        line += f'  ({schedule})'
    print(line)
    if desc:
        print(f'       {desc}')
    if url:
        print(f'       clawflows install {url}')
    print()
count = len(d.get('workflows', []))
if count == 0:
    print('    No workflows found.')
" 2>/dev/null
}

cmd_web_explore() {
  local query="${1:-}"

  if [ "$query" = "recommended" ] || [ -z "$query" ]; then
    echo ""
    echo "  Recommended ClawFlows:"
    echo "  ──────────────────────"
    local response
    response="$(curl -sf "$HUB_URL/api/explore")" || die "Could not reach ClawFlows.ai"
    _print_explore_results "$response"
    echo "  Browse more at https://clawflows.ai"
    echo ""
  else
    echo ""
    echo "  Exploring: $query"
    echo "  ──────────────────────"
    local encoded_query
    encoded_query="$(printf '%s' "$query" | python3 -c 'import sys,urllib.parse; print(urllib.parse.quote(sys.stdin.read().strip()))' 2>/dev/null)"
    local response
    response="$(curl -sf "$HUB_URL/api/explore?q=$encoded_query")" || die "Could not reach ClawFlows.ai"
    _print_explore_results "$response"
    echo ""
  fi
}

cmd_web_search() {
  local query="${1:-}"
  [ -n "$query" ] || die "usage: clawflows search <query>"

  echo ""
  echo "  Search: $query"
  echo "  ──────────────────────"
  local encoded_query
  encoded_query="$(printf '%s' "$query" | python3 -c 'import sys,urllib.parse; print(urllib.parse.quote(sys.stdin.read().strip()))' 2>/dev/null)"
  local response
  response="$(curl -sf "$HUB_URL/api/explore?q=$encoded_query")" || die "Could not reach ClawFlows.ai"
  _print_explore_results "$response"
  echo ""
}

cmd_web_install() {
  local ref="$1"
  local agent_name workflow_name

  # Parse URL (https://clawflows.ai/username/slug) or @username/slug
  case "$ref" in
    https://clawflows.ai/*)
      # Strip the domain and leading slash
      local path
      path="$(printf '%s' "$ref" | sed 's|https://clawflows.ai/||')"
      agent_name="$(printf '%s' "$path" | cut -d/ -f1)"
      workflow_name="$(printf '%s' "$path" | cut -d/ -f2)"
      ;;
    http*://*)
      die "Only clawflows.ai URLs are supported"
      ;;
    @*)
      agent_name="$(printf '%s' "$ref" | sed 's/^@//' | cut -d/ -f1)"
      workflow_name="$(printf '%s' "$ref" | cut -d/ -f2)"
      ;;
    *)
      agent_name="$(printf '%s' "$ref" | cut -d/ -f1)"
      workflow_name="$(printf '%s' "$ref" | cut -d/ -f2)"
      ;;
  esac

  [ -n "$agent_name" ] && [ -n "$workflow_name" ] || die "usage: clawflows install <url>  (e.g. https://clawflows.ai/dave/check-email)"

  echo "Installing @$agent_name/$workflow_name from ClawFlows.ai..."

  # Fetch workflow from hub
  local response http_code
  http_code="$(curl -s -o /tmp/clawflows_install.json -w '%{http_code}' "$HUB_URL/api/workflows/$agent_name/$workflow_name")"
  if [ "$http_code" = "403" ]; then
    die "This workflow is private. Contact the owner to request access."
  elif [ "$http_code" != "200" ]; then
    die "Workflow not found: @$agent_name/$workflow_name"
  fi
  response="$(cat /tmp/clawflows_install.json)"

  local content version name agent_id
  content="$(printf '%s' "$response" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("content",""))' 2>/dev/null)"
  version="$(printf '%s' "$response" | grep -o '"version":[0-9]*' | sed 's/"version"://')"
  name="$(printf '%s' "$response" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("name",""))' 2>/dev/null)"
  agent_id="$(printf '%s' "$response" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("agent_id",""))' 2>/dev/null)"

  [ -n "$content" ] || die "Workflow has no content. The author hasn't synced it yet."
  [ -n "$agent_id" ] || die "Server did not return agent_id. Try updating your CLI."

  # Save to installed/{agent_id}/{slug}/
  local target_dir="$INSTALLED_DIR/$agent_id/$workflow_name"
  mkdir -p "$target_dir"
  printf '%s' "$content" > "$target_dir/WORKFLOW.md"

  # Read schedule from the installed workflow
  local inst_schedule
  inst_schedule="$(get_field "$target_dir/WORKFLOW.md" schedule)"

  # Track in clawflows.json
  local now
  now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  _json_add "{\"name\":\"$workflow_name\",\"schedule\":\"${inst_schedule:-}\",\"path\":\"installed/$agent_id/$workflow_name\",\"source\":\"installed\",\"agent_id\":\"$agent_id\",\"username\":\"$agent_name\",\"version\":${version:-1},\"created_at\":\"$now\"}"

  echo ""
  echo "  ✅ Installed $name (@$agent_name/$workflow_name) v${version:-1}"
  echo "     Saved to: $target_dir/WORKFLOW.md"
  echo ""
  echo "  Enable it with: clawflows enable $workflow_name"
  echo ""
}

cmd_web_update() {
  local token
  token="$(_hub_get_token)"

  # Build installed list from clawflows.json
  local installed_json
  installed_json="$(python3 -c "
import sys, json
data = json.load(sys.stdin)
result = []
for entry in data:
    if entry.get('source') == 'installed':
        agent_id = entry.get('agent_id', '')
        result.append({
            'agent_id': agent_id,
            'slug': entry.get('name', ''),
            'version': entry.get('version', 1)
        })
print(json.dumps(result))
" <<< "$(_json_read)" 2>/dev/null || echo "[]")"

  if [ "$installed_json" = "[]" ]; then
    echo "No web-installed workflows to check."
    return
  fi

  echo "Checking for updates..."

  local response
  response="$(curl -sf -X POST "$HUB_URL/api/updates" \
    -H "Content-Type: application/json" \
    -d "{\"installed\":$installed_json}")" || die "Could not reach ClawFlows.ai"

  local updates
  updates="$(printf '%s' "$response" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for u in d.get('updates', []):
    print(f\"  @{u['agent']}/{u['slug']}: v{u['installed_version']} → v{u['latest_version']}\")
    for c in u.get('changelogs', []):
        print(f\"    v{c['version']}: {c['changelog']}\")
if not d.get('updates'):
    print('  All workflows are up to date.')
" 2>/dev/null)"

  echo ""
  echo "$updates"
  echo ""

  # Check if there are actual updates
  local has_updates
  has_updates="$(printf '%s' "$response" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print('yes' if d.get('updates') else 'no')
" 2>/dev/null)"

  if [ "$has_updates" = "yes" ]; then
    echo "  To update a workflow, re-install it:"
    echo "    clawflows install @username/workflow-name"
    echo ""
  fi
}

cmd_web() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    login)    cmd_web_login "${1:-}" ;;
    logout)   cmd_web_logout ;;
    whoami)   cmd_web_whoami ;;
    sync)     cmd_web_sync ;;
    install)  [ -n "${1:-}" ] || die "usage: clawflows install <url>"; cmd_web_install "$1" ;;
    explore)  cmd_web_explore "${1:-}" ;;
    search)   cmd_web_search "${1:-}" ;;
    update)   cmd_web_update ;;
    *)
      echo "ClawFlows Web commands:"
      echo ""
      echo "  clawflows login [token]                    Sign in to ClawFlows.ai"
      echo "  clawflows sync                             Push your workflows to ClawFlows.ai"
      echo "  clawflows explore [query]                  Browse workflows (default: recommended)"
      echo "  clawflows search <query>                   Search workflows by name"
      echo "  clawflows install <url>                    Install a workflow from ClawFlows.ai"
      echo "  clawflows whoami                           Check your login status"
      echo "  clawflows logout                           Sign out"
      echo ""
      ;;
  esac
}

# ── Main ────────────────────────────────────────────────────────────────────

[ $# -ge 1 ] || { cmd_help; exit 0; }

case "$1" in
  list)      cmd_list "${2:-all}" ;;
  create)    cmd_create "${2:-}" "${3:-}" ;;
  run)       [ $# -ge 2 ] || die "usage: clawflows run <name>"; cmd_run "$2" ;;
  logs)      cmd_logs "${2:-}" "${3:-}" ;;
  enable)    [ $# -ge 2 ] || die "usage: clawflows enable <name>"; cmd_enable "$2" ;;
  disable)   [ $# -ge 2 ] || die "usage: clawflows disable <name>"; cmd_disable "$2" ;;
  edit)      [ $# -ge 2 ] || die "usage: clawflows edit <name>"; cmd_edit "$2" ;;
  open)      [ $# -ge 2 ] || die "usage: clawflows open <name>"; cmd_open "$2" ;;
  validate)  [ $# -ge 2 ] || die "usage: clawflows validate <name>"; cmd_validate "$2" ;;
  share)     [ $# -ge 2 ] || die "usage: clawflows share <name>"; cmd_share "$2" "${3:-}" ;;
  import)    [ $# -ge 2 ] || die "usage: clawflows import <url>"; cmd_import "$2" ;;
  backup)    cmd_backup "${2:-}" ;;
  restore)   cmd_restore "${2:-}" ;;
  update)    cmd_update ;;
  uninstall) cmd_uninstall ;;
  sync-agent) cmd_sync ;;
  doctor)    cmd_doctor ;;
  explore)   cmd_web_explore "${2:-}" ;;
  search)    [ $# -ge 2 ] || die "usage: clawflows search <query>"; cmd_web_search "$2" ;;
  install)   [ $# -ge 2 ] || die "usage: clawflows install <url>"; cmd_web_install "$2" ;;
  login)     cmd_web_login "${2:-}" ;;
  logout)    cmd_web_logout ;;
  whoami)    cmd_web_whoami ;;
  sync)      cmd_web_sync ;;
  web)       cmd_web "${2:-}" "${3:-}" ;;
  help|--help|-h) cmd_help ;;
  *)         cmd_help ;;
esac
