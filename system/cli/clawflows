#!/usr/bin/env bash
set -euo pipefail

# ── Config ──────────────────────────────────────────────────────────────────
# Resolve symlinks so this works when called via ~/.local/bin/clawflows
SELF="$0"
if [ -L "$SELF" ]; then
  SELF="$(readlink "$SELF")"
fi
CLAWFLOWS_DIR="$(cd "$(dirname "$SELF")/../.." && pwd)"

# Detect OpenClaw workspace (supports custom workspace directories)
_oc_workspace=""
if [ -f "$HOME/.openclaw/openclaw.json" ]; then
  _oc_workspace="$(grep -o '"workspace"[[:space:]]*:[[:space:]]*"[^"]*"' "$HOME/.openclaw/openclaw.json" | sed 's/.*:.*"\([^"]*\)"/\1/' | head -1 || true)"
fi
_oc_workspace="${_oc_workspace:-$HOME/.openclaw/workspace}"

AGENTS_MD="${AGENTS_MD:-$_oc_workspace/AGENTS.md}"
BACKUP_DIR="${BACKUP_DIR:-$_oc_workspace/clawflows-backups}"
CREATED_DIR="$CLAWFLOWS_DIR/clawflows/created"
INSTALLED_DIR="$CLAWFLOWS_DIR/clawflows/installed"
CLAWFLOWS_JSON="$CLAWFLOWS_DIR/clawflows/clawflows.json"
BIN_TARGET="$HOME/.local/bin/clawflows"

START_MARKER="<!-- clawflows:start -->"
END_MARKER="<!-- clawflows:end -->"

# ── Find openclaw (may not be in PATH when run from a non-interactive shell) ──
_find_openclaw() {
  # Allow override for testing
  if [ "${OPENCLAW_CMD+set}" = "set" ]; then
    echo "${OPENCLAW_CMD:-}"
    return
  fi
  if command -v openclaw >/dev/null 2>&1; then
    echo "openclaw"
    return
  fi
  for try_path in "$HOME/.local/bin/openclaw" "/usr/local/bin/openclaw" "/opt/homebrew/bin/openclaw"; do
    if [ -x "$try_path" ]; then
      echo "$try_path"
      return
    fi
  done
}

# ── clawflows.json Helpers ─────────────────────────────────────────────────

_json_read() {
  if [ -f "$CLAWFLOWS_JSON" ]; then
    cat "$CLAWFLOWS_JSON"
  else
    echo "[]"
  fi
}

_json_find() {
  local name="$1"
  python3 -c "
import sys, json
data = json.load(sys.stdin)
for entry in data:
    if entry.get('name') == '$name':
        print(json.dumps(entry))
        break
" <<< "$(_json_read)" 2>/dev/null
}

_json_add() {
  local entry_json="$1"
  local tmpfile
  tmpfile="$(mktemp)"
  python3 -c "
import sys, json
data = json.load(sys.stdin)
entry = json.loads('$entry_json')
# Remove existing entry with same name
data = [e for e in data if e.get('name') != entry.get('name')]
data.append(entry)
with open('$tmpfile', 'w') as f:
    json.dump(data, f, indent=2)
" <<< "$(_json_read)" 2>/dev/null
  mv "$tmpfile" "$CLAWFLOWS_JSON"
}

_json_remove() {
  local name="$1"
  local tmpfile
  tmpfile="$(mktemp)"
  python3 -c "
import sys, json
data = json.load(sys.stdin)
data = [e for e in data if e.get('name') != '$name']
with open('$tmpfile', 'w') as f:
    json.dump(data, f, indent=2)
" <<< "$(_json_read)" 2>/dev/null
  mv "$tmpfile" "$CLAWFLOWS_JSON"
}

_json_is_enabled() {
  local name="$1"
  local result
  result="$(_json_find "$name")"
  [ -n "$result" ]
}

