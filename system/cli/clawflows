die() { echo "error: $1" >&2; exit 1; }

# Validate workflow name to prevent path traversal attacks
validate_workflow_name() {
  local name="$1"
  
  # Reject names containing newlines (prevents bypass of single-line regex)
  # Use case statement which handles newlines correctly (grep -q $'\n' is broken)
  case "$name" in
    *$'\n'*)
      die "invalid workflow name: '$name' (must not contain newlines)"
      ;;
  esac
  
  # Only allow alphanumeric, dashes, underscores (no slashes, dots, or other special chars)
  # Must start with alphanumeric, max length 64 chars
  if ! printf '%s' "$name" | grep -qE '^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$'; then
    die "invalid workflow name: '$name' (use only letters, numbers, dashes, underscores; max 64 chars)"
  fi
}

# Extract a frontmatter field from a WORKFLOW.md file.
get_field() {
  local file="$1" field="$2"
  awk -v field="$field" '
    BEGIN { in_fm=0 }
    /^---$/ { in_fm++; next }
    in_fm == 1 && $0 ~ "^" field ":" {
      sub("^" field ":[ ]*", "")
      gsub(/^["'"'"']|["'"'"']$/, "")
      print
      exit
    }
    in_fm >= 2 { exit }
  ' "$file"
}

# Find workflow source: created/ takes priority, then installed/
_find_workflow() {
  local name="$1"
  if [ -d "$CREATED_DIR/$name" ]; then
    echo "$CREATED_DIR/$name"
  elif [ -d "$INSTALLED_DIR" ]; then
    for agent_dir in "$INSTALLED_DIR"/*/; do
      [ -d "$agent_dir$name" ] && echo "$agent_dir$name" && return
    done
  fi
}

# Build a line for a workflow: emoji + name + source
_workflow_line() {
  local dir="$1"
  local source="${2:-}"
  local name emoji label
  name="$(basename "$dir")"
  emoji=""
  if [ -f "$dir/WORKFLOW.md" ]; then
    emoji="$(get_field "$dir/WORKFLOW.md" emoji)"
  fi
  label="${emoji:+$emoji }$name"
  if [ -n "$source" ]; then
    printf "    %-40s %s" "$label" "$source"
  else
    printf "    %s" "$label"
  fi
}

